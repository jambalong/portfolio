---
import Layout from '@/layouts/Layout.astro';
import Navigation from '@/components/Navigation';
import Footer from '@/components/Footer';

const pathname = Astro.url.pathname;
---

<Layout title="404 | John Alvin Ambalong">
  <div class="dt-bg min-h-screen flex flex-col">
    <Navigation client:load />

    <main class="flex-1 flex items-center justify-center px-6">
      <div class="w-full max-w-4xl mx-auto">

        <p class="dt-eyebrow mb-4" style="color: var(--dt-red)">404</p>

        <h1 class="dt-display mb-6" style="font-size: clamp(32px, 5vw, 56px)">
          Page <em style="color: var(--dt-red)">not found</em>
        </h1>

        <div class="dt-rule mb-8" style="max-width: 320px; background: linear-gradient(90deg, var(--dt-border), rgba(255,106,106,0.35), var(--dt-border))" />

        <p class="dt-body mb-3" style="font-size: 14px">
          The path you're looking for doesn't exist or has been moved.
        </p>
        <p class="dt-mono mb-10" style="color: var(--dt-red)">
          {pathname}
        </p>

        <a href="/" class="dt-btn-primary" style="border-color: var(--dt-green); color: var(--dt-green); background: rgba(106,255,176,0.1)">Return Home</a>

      </div>
    </main>

    <Footer />
  </div>
</Layout>
